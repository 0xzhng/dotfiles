###############################################
# Ghostty profile for Neovim sessions
# - Matches the main profile visuals
# - Disables inner padding so Neovim gets full screen space
###############################################
confirm-close-surface = false

# Terminal basics – jump straight into Neovim
term = xterm-ghostty
command = nvim

# Match the JetBrains Mono look already used in Waybar
font-family = "JetBrainsMono Nerd Font"
font-size = 13
font-shaping-break = cursor

# Window feel – rely on Hyprland for rounding, let apps draw edge to edge
window-decoration = none
window-theme = ghostty
window-padding-x = 0
window-padding-y = 0

# Ghostty-owned color + transparency
background = #222
background-opacity = 0.67
background-opacity-cells = false
background-blur = false
unfocused-split-opacity = 1

# Cursor setup – keep default block cursor but tint + animate via shader
cursor-style = block
cursor-style-blink = true
cursor-color = cell-foreground
cursor-text = #05070b
cursor-click-to-move = true

# Shell integration disabled to avoid close confirmations while tmux runs
shell-integration = none

# Ghost cursor shader
custom-shader = ~/.config/ghostty/shaders/cursor_smear.glsl
custom-shader-animation = always
